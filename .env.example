# Transport
# "stdio" = local subprocess (default). "http" = standalone Streamable HTTP server.
# MCP_TRANSPORT=http
# MCP_PORT=3000
# MCP_HOST=127.0.0.1   # 0.0.0.0 to expose remotely
# MCP_AUTH_TOKEN=       # set to enforce Bearer auth (required when exposing remotely)
# LOG_TO_STDOUT=        # true/false. Mirror INFO/DEBUG logs to stdout. If unset,
#                       # auto-enabled when MCP_TRANSPORT=http (Docker/HTTP logs are
#                       # observable); in stdio mode stdout stays clean for JSON-RPC.

# Lightpanda (level 1 — always the default browser, not configurable)
LIGHTPANDA_BASE_PORT=9222
LIGHTPANDA_POOL_SIZE=5
# Release tag to download if the binary is missing. Any lightpanda-io/browser tag
# works (asset names are stable across tags). "nightly" tracks the latest build;
# pin to a stable tag like "0.3.3" for reproducible deployments.
LIGHTPANDA_VERSION=nightly

# Fallback browser (level 2). Used once when Lightpanda crashes, times out, or
# is bot-detected. One of: headless | headful | browserbase | browserless | none
# (default none).
#   headless    -> headless Chrome (sized by CHROME_POOL_SIZE)
#   headful     -> headful Chrome; on headless Linux requires xvfb (apt-get install xvfb)
#   browserbase -> cloud browsers via puppeteer.connect (needs BROWSERBASE_* below)
#   browserless -> cloud browsers via puppeteer.connect (needs BROWSERLESS_* below)
#   none        -> no fallback; Lightpanda errors propagate honestly
FALLBACK_BROWSER=none

# Domains that skip Lightpanda entirely and start directly on the level-2
# fallback. Requires FALLBACK_BROWSER != none (ignored with a warning otherwise).
# Comma-separated, subdomain-aware (e.g. "g2.com" matches "www.g2.com", "sellers.g2.com").
# SKIP_LIGHTPANDA_DOMAINS=g2.com,linkedin.com

# Fallback pool sizes
CHROME_POOL_SIZE=1
# HEADFUL_CHROME_POOL_SIZE=1

# Browserbase (cloud). Required only when FALLBACK_BROWSER=browserbase.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSERBASE_API_URL=https://api.browserbase.com/v1
# BROWSERBASE_CONNECT_HOST=wss://connect.browserbase.com

# Browserless (cloud). Required only when FALLBACK_BROWSER=browserless.
# Region-specific production endpoint — use your account's region (sfo/lon/ams).
# BROWSERLESS_TOKEN=
# BROWSERLESS_ENDPOINT=wss://production-sfo.browserless.io

# Session management
# MAX_SESSIONS=0   # 0 = unlimited; otherwise a hard cap on concurrent sessions

# Stealth / Anti-Detection
STEALTH_ENABLED=true
HUMAN_DELAYS_ENABLED=true
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
# Proxy applied to every browser layer: Lightpanda (via its --http-proxy flag)
# and the Chrome fallback (via --proxy-server). May include basic auth:
# PROXY_SERVER=http://user:pass@host:port

# Cleanup
CLEANUP_INTERVAL_MS=600000
SESSION_IDLE_TIMEOUT_MS=300000

# Resource Logging
RESOURCE_LOGGING_ENABLED=true

# Navigation
NAVIGATE_WAIT_UNTIL=domcontentloaded
NAVIGATE_TIMEOUT=30000

# Rate limiting (server-wide min delay between navigates to listed domains).
# Patterns support wildcards:
#   "*"            -> all domains (each throttled independently per host)
#   "*.reddit.com" -> subdomains of reddit only (excludes reddit.com itself)
#   "g2.com"       -> g2.com and its subdomains (subdomains share one bucket)
# Disabled unless both a non-empty domain list and a non-zero delay are set.
# RATE_LIMIT_JITTER_MS adds a random 0..value ms on top of each delay so pacing
# isn't a fixed, fingerprintable interval. Defaults to 0 (no jitter).
# RATE_LIMIT_DOMAINS=*.reddit.com,g2.com
# RATE_LIMIT_MIN_DELAY_MS=2000
# RATE_LIMIT_JITTER_MS=1500

# Snapshot
SNAPSHOT_FLATTEN=true
SNAPSHOT_TEXT_TRIM_LENGTH=200
