{
  "name": "slimatlas",
  "version": "1.0.0",
  "description": "SlimAtlas MCP Server - Model Context Protocol server for browser automation using Lightpanda",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "lightpanda",
    "browser",
    "automation",
    "model-context-protocol"
  ],
  "license": "MIT"
}
